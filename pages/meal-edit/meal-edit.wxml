<view class="page">
  <view class="shell">
    <view class="hero">
      <text class="hero-title">{{title}}</text>
      <text class="hero-subtitle">{{sourceLabel}} · 记录你今天实际吃了什么。支持同一天多条记录。</text>
    </view>

    <view class="card">
      <view class="form-item">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view class="picker">{{date}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">时间</text>
        <picker mode="time" value="{{time}}" bindchange="onTimeChange">
          <view class="picker">{{time}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">餐次</text>
        <picker range="{{mealTypeOptions}}" value="{{mealTypeIndex}}" bindchange="onMealTypeChange">
          <view class="picker">{{mealTypeOptions[mealTypeIndex]}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">吃的什么</text>
        <input class="input" value="{{foodName}}" placeholder="例如：牛肉面" bindinput="onFoodInput" />
      </view>

      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea class="textarea" value="{{note}}" placeholder="可留空" bindinput="onNoteInput"></textarea>
      </view>

      <view class="form-help">{{hint}}</view>
      <view class="actions" style="margin-top: 16rpx;">
        <button class="btn btn-primary" bindtap="saveRecord">保存</button>
        <button class="btn btn-ghost" bindtap="cancelEdit">取消</button>
      </view>
    </view>
  </view>
</view>
