.mode-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.mode-tab {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #f7f1e8;
  color: #7d6c59;
  font-size: 28rpx;
  font-weight: 600;
}

.mode-tab-active {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  box-shadow: 0 10rpx 22rpx rgba(217, 119, 6, 0.18);
}

.rolling-panel {
  min-height: 240rpx;
  padding: 20rpx;
  margin: 12rpx 0 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff7ec 0%, #ffffff 100%);
  border: 1rpx solid rgba(217, 119, 6, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.rolling-panel-active {
  box-shadow: inset 0 0 0 2rpx rgba(245, 158, 11, 0.14);
}

.rolling-track {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.rolling-divider {
  width: 72%;
  height: 2rpx;
  margin: 12rpx 0;
  background: repeating-linear-gradient(
    90deg,
    rgba(217, 119, 6, 0.18) 0,
    rgba(217, 119, 6, 0.18) 18rpx,
    transparent 18rpx,
    transparent 34rpx
  );
}

.rolling-item {
  text-align: center;
  line-height: 1.3;
  transition: all 0.12s ease-out;
}

.rolling-center {
  font-size: 42rpx;
  font-weight: 800;
  color: #b45309;
  padding: 16rpx 0;
}

.rolling-faded {
  font-size: 24rpx;
  color: #b7a48d;
}

.action-main {
  width: 100%;
  margin-bottom: 16rpx;
}

.two-column-actions {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  box-sizing: border-box;
}

.two-column-actions .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 14rpx 10rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 1.35;
  white-space: normal;
}

.draw-shortcuts {
  margin-top: 0;
}

.result-card {
  gap: 20rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.result-title {
  margin: 0;
}

.result-help-trigger {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff5e7;
  color: #9a5c00;
}

.result-help-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #f59e0b;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
}

.result-help-text {
  font-size: 22rpx;
  line-height: 1.2;
}

.result-content {
  margin-top: 16rpx;
}

.result-status-row {
  align-items: flex-start;
  gap: 16rpx;
}

.result-name {
  flex: 1 1 auto;
}

.result-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  margin-top: 20rpx;
}

.result-action-grid .btn {
  width: 100%;
  min-width: 0;
  min-height: 76rpx;
  margin: 0;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  font-size: 23rpx;
  white-space: normal;
  text-align: center;
  line-height: 1.3;
}

.detail-action-row {
  display: flex;
  width: 100%;
  margin-top: 16rpx;
}

.detail-action-row .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
}

.section-link {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  margin: 0;
  padding: 8rpx 4rpx 8rpx 12rpx;
  color: #8a7964;
  font-size: 22rpx;
  line-height: 1.2;
}

.section-link-arrow {
  font-size: 28rpx;
  line-height: 1;
}

.draw-item-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.draw-item-actions .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 13rpx 10rpx;
  box-sizing: border-box;
  font-size: 24rpx;
}

.draw-item-detail-row {
  display: flex;
  width: 100%;
  margin-top: 16rpx;
}

.draw-item-detail-row .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
}
