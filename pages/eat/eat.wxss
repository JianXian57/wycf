.mode-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.mode-tab {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #f7f1e8;
  color: #7d6c59;
  font-size: 28rpx;
  font-weight: 600;
}

.mode-tab-active {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  box-shadow: 0 10rpx 22rpx rgba(217, 119, 6, 0.18);
}

.rolling-panel {
  min-height: 240rpx;
  padding: 20rpx;
  margin: 12rpx 0 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff7ec 0%, #ffffff 100%);
  border: 1rpx solid rgba(217, 119, 6, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.rolling-panel-active {
  box-shadow: inset 0 0 0 2rpx rgba(245, 158, 11, 0.14);
}

.rolling-track {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.rolling-divider {
  width: 72%;
  height: 2rpx;
  margin: 12rpx 0;
  background: repeating-linear-gradient(
    90deg,
    rgba(217, 119, 6, 0.18) 0,
    rgba(217, 119, 6, 0.18) 18rpx,
    transparent 18rpx,
    transparent 34rpx
  );
}

.rolling-item {
  text-align: center;
  line-height: 1.3;
  transition: all 0.12s ease-out;
}

.rolling-center {
  font-size: 42rpx;
  font-weight: 800;
  color: #b45309;
  padding: 16rpx 0;
}

.rolling-faded {
  font-size: 24rpx;
  color: #b7a48d;
}

.action-main {
  width: 100%;
  margin-bottom: 16rpx;
}

.mini-btn {
  padding: 14rpx 20rpx;
  font-size: 22rpx;
}

.top-link {
  flex: 0 0 auto !important;
  min-width: auto !important;
}

.result-card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.result-note {
  margin-top: 10rpx;
  color: #8b8b8b;
  font-size: 22rpx;
}
