<view class="page">
  <view class="shell">
    <view class="hero">
      <text class="hero-title">{{pageTitle}}</text>
      <text class="hero-subtitle">{{pageSubtitle}}</text>
    </view>

    <view class="card">
      <view class="row-between">
        <text class="section-title">{{rollingSectionTitle}}</text>
        <text class="tag tag-muted">{{resultState === 'animating' ? '抽取中' : rollingHint}}</text>
      </view>

      <view class="rolling-panel {{resultState === 'animating' ? 'rolling-panel-active' : ''}}">
        <view wx:if="{{rollingWindow.length}}" class="rolling-track">
          <view class="rolling-divider"></view>
          <view class="rolling-item rolling-faded">{{rollingWindow[0].name}}</view>
          <view class="rolling-divider"></view>
          <view class="rolling-item rolling-center">{{rollingWindow[1].name}}</view>
          <view class="rolling-divider"></view>
          <view class="rolling-item rolling-faded">{{rollingWindow[2].name}}</view>
          <view class="rolling-divider"></view>
        </view>
        <view wx:else class="empty">
          <view class="empty-title">{{emptyTitle}}</view>
          <view class="empty-subtitle">{{emptySubtitle}}</view>
        </view>
      </view>

      <button class="btn btn-primary action-main" bindtap="startDraw" disabled="{{resultState !== 'idle' || !canDraw}}">
        {{resultState === 'animating' ? '抽取中...' : '开始抽取'}}
      </button>

      <view class="aux-actions">
        <button class="btn btn-soft aux-btn" bindtap="goManage">{{manageButtonText}}</button>
        <button class="btn btn-ghost aux-btn" bindtap="goDrawHistory">查看抽取记录</button>
      </view>
    </view>

    <view class="card result-card" wx:if="{{resultCard}}">
      <view class="result-head">
        <text class="section-title result-title">{{resultSectionTitle}}</text>
        <view class="result-help-trigger" bindtap="showResultGuide">
          <text class="result-help-icon">!</text>
          <text class="result-help-text">结果说明</text>
        </view>
      </view>

      <view class="result-content">
        <view class="row-between result-status-row">
          <view class="list-item-title result-name">{{resultCard.name}}</view>
          <text class="tag {{resultCard.recorded ? 'tag-success' : 'tag-muted'}}">{{resultCard.statusLabel}}</text>
        </view>
        <view class="list-item-subtitle" wx:if="{{resultCard.category || resultCard.difficulty}}">
          {{resultCard.category || '未分类'}}
          <text wx:if="{{resultCard.difficulty}}"> · {{resultCard.difficulty}}</text>
          <text wx:if="{{resultCard.durationMinutes}}"> · {{resultCard.durationMinutes}} 分钟</text>
        </view>
        <view class="form-help" wx:if="{{resultCard.note}}">{{resultCard.note}}</view>
      </view>

      <view class="result-grid">
        <button
          class="btn btn-primary result-grid-btn"
          bindtap="rememberAndStop"
          disabled="{{resultState !== 'pending' || resultCard.recorded}}"
        >好，就吃这个，记下来！</button>
        <button
          class="btn btn-soft result-grid-btn"
          bindtap="redrawWithoutSaving"
          disabled="{{resultState !== 'pending' || resultCard.recorded}}"
        >不算，再抽一次！</button>
        <button
          class="btn btn-ghost result-grid-btn"
          bindtap="keepAndRedraw"
          disabled="{{resultState !== 'pending' || resultCard.recorded}}"
        >暂记一下，再抽个别的吧~</button>
        <button
          class="btn btn-ghost result-grid-btn"
          bindtap="discardResultCard"
          disabled="{{resultState !== 'pending' || resultCard.recorded}}"
        >算了，不抽了~</button>
      </view>

      <view class="actions result-detail-action" wx:if="{{resultCard.canOpenDetail}}">
        <button class="btn btn-soft" data-draw-id="{{resultCard.drawRecordId}}" bindtap="openRecipeDetail">{{recipeActionText}}</button>
      </view>
    </view>

    <view class="card">
      <view class="row-between">
        <text class="section-title">最近抽取记录</text>
        <button class="mini-link" bindtap="goDrawHistory">查看全部 ></button>
      </view>

      <view wx:if="{{recentDraws.length}}" class="list">
        <view class="list-item" wx:for="{{recentDraws}}" wx:key="id" wx:for-item="drawItem">
          <view class="row-between">
            <view>
              <view class="list-item-title">{{drawItem.resultName}}</view>
              <view class="list-item-subtitle">{{drawItem.exactLabel}}</view>
            </view>
            <text class="tag {{drawItem.recorded ? 'tag-success' : 'tag-muted'}}">{{drawItem.statusLabel}}</text>
          </view>
          <view class="form-help">{{drawItem.timeLabel}}</view>
          <view class="record-actions">
            <button
              class="btn {{drawItem.canRemember ? 'btn-soft' : 'btn-ghost'}} record-action-btn"
              data-id="{{drawItem.id}}"
              bindtap="rememberDraw"
              disabled="{{resultState === 'animating' || resultState === 'navigating' || resultState === 'completed' || !drawItem.canRemember}}"
            >{{drawItem.rememberLabel}}</button>
            <button
              class="btn btn-danger record-action-btn"
              data-id="{{drawItem.id}}"
              data-name="{{drawItem.resultName}}"
              bindtap="removeRecentDraw"
              disabled="{{resultState === 'animating' || resultState === 'navigating' || resultState === 'completed'}}"
            >删除</button>
          </view>
          <view class="actions" wx:if="{{drawItem.canOpenDetail}}">
            <button class="btn btn-ghost" data-draw-id="{{drawItem.id}}" bindtap="openRecipeDetail">查看菜谱</button>
          </view>
        </view>
      </view>

      <view wx:else class="empty">
        <view class="empty-title">还没有抽取记录</view>
        <view class="empty-subtitle">完成一次抽取后，这里会自动出现最近 10 条记录。</view>
      </view>
    </view>
  </view>
</view>
