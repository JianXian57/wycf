.overview-head {
  gap: 16rpx;
  align-items: center;
}

.overview-title {
  margin-bottom: 0;
  flex: 1 1 auto;
  min-width: 0;
}

.record-header-links {
  flex: 0 0 auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.compact-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 0;
  margin: 0;
  padding: 10rpx 14rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
}

.compact-link::after {
  border: none;
}

.compact-link-ghost {
  color: #5d5244;
  background: #f7f1e8;
}

.compact-link-soft {
  color: #9a5c00;
  background: #fff5e7;
}

.overview-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.overview-action-btn {
  flex: 1 1 200rpx;
  min-width: 0;
}

.group-header {
  gap: 16rpx;
  align-items: flex-start;
}

.record-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.record-main {
  flex: 1 1 auto;
  min-width: 0;
}

.record-item-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.record-item-actions .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 13rpx 10rpx;
  box-sizing: border-box;
  font-size: 22rpx;
}

.empty-record-primary {
  width: 100%;
  margin-top: 16rpx;
}

.empty-record-primary .btn {
  width: 100%;
  min-width: 0;
  margin: 0;
}

.record-empty-links {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag-ghost {
  background: #f7f1e8;
  color: #5d5244;
}
