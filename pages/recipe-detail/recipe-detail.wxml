<view class="page">
  <view class="shell">
    <view class="hero" wx:if="{{recipe}}">
      <text class="hero-title">{{recipe.name}}</text>
      <text class="hero-subtitle">{{sourceLabel}}{{exactLabel ? ' · ' + exactLabel : ''}}</text>
    </view>

    <view wx:if="{{recipe}}" class="card">
      <view class="row-wrap">
        <text class="tag">{{recipe.category || '未分类'}}</text>
        <text class="tag tag-muted">{{recipe.difficulty}}</text>
        <text class="tag tag-success">{{recipe.durationMinutes}} 分钟</text>
      </view>

      <view class="divider"></view>

      <text class="section-title">食材</text>
      <view class="list">
        <view class="list-item" wx:for="{{recipe.ingredients}}" wx:key="*this" wx:for-item="ingredient">
          <view class="list-item-title">{{ingredient}}</view>
        </view>
      </view>

      <view class="divider"></view>

      <text class="section-title">步骤</text>
      <view class="list">
        <view class="list-item" wx:for="{{recipe.steps}}" wx:key="*this" wx:for-item="step" wx:for-index="stepIndex">
          <view class="list-item-title">步骤 {{stepIndex + 1}}</view>
          <view class="list-item-subtitle">{{step}}</view>
        </view>
      </view>

      <view class="divider" wx:if="{{recipe.note}}"></view>
      <view wx:if="{{recipe.note}}">
        <text class="section-title">备注</text>
        <view class="form-help">{{recipe.note}}</view>
      </view>
    </view>
  </view>
</view>
